# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/zenops

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Cognee Memory Backend
COGNEE_API_URL=http://localhost:8001
COGNEE_API_KEY=your_cognee_api_key_here

# Internal API Auth (shared secret for discord-bot -> backend)
INTERNAL_AUTH_TOKEN=zenops-internal-secret

# Bot Activity (optional, defaults below)
BACKEND_URL=http://127.0.0.1:8000
BOT_ACTIVITY_TYPE=playing
BOT_ACTIVITY_TEXT=Managing your infrastructure
